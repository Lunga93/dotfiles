#!/usr/bin/env bash
set -euo pipefail

# fetch-wallpaper
# Downloads a random wallpaper using Unsplash and triggers set-wallpaper

CONFIG_DIR="$HOME/.config/dotfiles"
OUT_DIR="$HOME/Pictures/wallpapers"
OUT_FILE="$OUT_DIR/daily.jpg"
OUT_TMP="$OUT_DIR/daily.tmp"

mkdir -p "$OUT_DIR"

# Helper to validate downloaded image
validate_image() {
    if [ ! -s "$OUT_TMP" ]; then return 1; fi
    # Check if file command identifies it as image
    if ! file --mime-type "$OUT_TMP" | grep -q "image/"; then
        echo "Error: Downloaded file is not a valid image (detected: $(file -b --mime-type "$OUT_TMP"))." >&2
        rm -f "$OUT_TMP"
        return 1
    fi
    return 0
}

# Priority order for wallpaper source:
# 1) If $LOCAL_WALLPAPER_DIR is set and contains files, pick a random local file
# 2) If UNSPLASH_API_KEY exists at $CONFIG_DIR/unsplash_api_key use Unsplash
# 3) Fallback to Lorem Picsum (no API key required)

LOCAL_WALLPAPER_DIR="${LOCAL_WALLPAPER_DIR:-$HOME/Pictures/wallpapers/local}"
UNSPLASH_KEY_FILE="$CONFIG_DIR/unsplash_api_key"

choose_local() {
    if [ -d "$LOCAL_WALLPAPER_DIR" ]; then
        # find images and pick one randomly
        mapfile -t files < <(find "$LOCAL_WALLPAPER_DIR" -type f \( -iname '*.jpg' -o -iname '*.jpeg' -o -iname '*.png' \) )
        if [ "${#files[@]}" -gt 0 ]; then
            # pick random
            idx=$((RANDOM % ${#files[@]}))
            echo "${files[$idx]}"
            return 0
        fi
    fi
    return 1
}

download_reddit() {
    SUBREDDITS=("EarthPorn" "CityPorn" "SpacePorn" "ArchitecturePorn" "wallpapers" "SkyPorn")
    # Pick random subreddit
    SUB=${SUBREDDITS[$RANDOM % ${#SUBREDDITS[@]}]}
    echo "Fetching top wallpaper from r/$SUB..."

    # Fetch JSON (User-Agent is required for Reddit API)
    JSON=$(curl -s -A "linux:dotfiles:v1.0 (by /u/anonymous)" "https://www.reddit.com/r/$SUB/top.json?t=week&limit=20") || return 1

    # Prefer high-resolution images: check reddit preview metadata for >=1920x1080
    IMG_URL=$(echo "$JSON" | \
        jq -r '.data.children[]?.data | select(.preview != null) | .preview.images[0].source.url as $u | .preview.images[0].source.width as $w | .preview.images[0].source.height as $h | {url:$u, w:$w, h:$h} | select(.w >= 1920 or .h >= 1080) | .url' | sed 's/\\&amp;/\&/g' | shuf -n 1)

    # Fallback: plain url fields (some posts don't include preview metadata)
    if [ -z "$IMG_URL" ] || [ "$IMG_URL" = "null" ]; then
        IMG_URL=$(echo "$JSON" | jq -r '.data.children[].data.url | select(endswith(".jpg") or endswith(".png") or endswith(".jpeg"))' | shuf -n 1)
    fi

    if [ -z "$IMG_URL" ] || [ "$IMG_URL" = "null" ]; then
        echo "No valid images found in r/$SUB"
        return 1
    fi

    echo "Downloading image from r/$SUB ($IMG_URL)..."
    curl -f -sSL -o "$OUT_TMP" "$IMG_URL" || return 1
    validate_image || return 1
}

download_bing() {
    echo "Fetching Photo of the Day from Bing..."
    # Randomize index between 0 (today) and 7 (a week ago)
    IDX=$((RANDOM % 8))

    # Fetch JSON
    JSON=$(curl -sSL "https://www.bing.com/HPImageArchive.aspx?format=js&idx=$IDX&n=1&mkt=en-US") || return 1

    # Extract relative URL
    REL_URL=$(echo "$JSON" | jq -r '.images[0].url')
    if [ -z "$REL_URL" ] || [ "$REL_URL" = "null" ]; then
        return 1
    fi

    FULL_URL="https://www.bing.com${REL_URL}"
    echo "Downloading image from Bing ($FULL_URL)..."
    curl -f -sSL -o "$OUT_TMP" "$FULL_URL" || return 1
    validate_image || return 1
}

download_picsum() {
    # Determine size: prefer WALLPAPER_SIZE env var or detect from sway outputs
    local size="${WALLPAPER_SIZE:-}"
    if [ -z "$size" ]; then
        if command -v swaymsg >/dev/null 2>&1 && command -v jq >/dev/null 2>&1; then
            size=$(swaymsg -t get_outputs 2>/dev/null | jq -r 'map(select(.active==true))[0].current_mode | "\(.width)x\(.height)"' 2>/dev/null || true)
        fi
    fi
    if [ -z "$size" ]; then
        # Ensure default is full HD
        size="1920x1080"
    fi
    # Picsum uses /WIDTH/HEIGHT
    size=${size/x/\/}
    local url="https://picsum.photos/${size}"
    echo "Downloading random image from picsum.photos (${size})..."
    curl -f -L -s -o "$OUT_TMP" "$url" || return 1
    validate_image || return 1
}

download_unsplash() {
    local apikey="$1"
    echo "Fetching random wallpaper from Unsplash (requesting full-HD, clean/minimal photos)..."
    # Use queries that favour clean/minimal photography suitable for wallpapers
    JSON=$(curl -sS -G "https://api.unsplash.com/photos/random" \
        -H "Accept-Version: v1" \
        -H "Authorization: Client-ID $apikey" \
        --data-urlencode "orientation=landscape" \
        --data-urlencode "query=minimal,clean,landscape,wallpaper" \
        --data-urlencode "content_filter=high" ) || return 1
    # Prefer the raw URL and request a cropped 1920x1080 image via Unsplash URL params
    IMG_RAW=$(echo "$JSON" | jq -r '.urls.raw // .urls.full // .urls.regular')
    if [ -n "$IMG_RAW" ] && [ "$IMG_RAW" != "null" ]; then
        # Append width/height and fit params to ensure full-HD output when supported
        IMG_URL="${IMG_RAW}&w=1920&h=1080&fit=crop&q=80"
    else
        IMG_URL=""
    fi
    if [ -z "$IMG_URL" ] || [ "$IMG_URL" = "null" ]; then
        return 1
    fi
    echo "Downloading image from Unsplash..."
    curl -f -sSL -o "$OUT_TMP" "$IMG_URL" || return 1
    validate_image || return 1
}

main() {
    LOGFILE="$HOME/.local/share/dotfiles/fetch-wallpaper.log"
    mkdir -p "$(dirname "$LOGFILE")"
    logger() { printf "%s %s\n" "$(date --iso-8601=seconds)" "$*" >> "$LOGFILE"; }

    # rotate logs (keep 30)
    if [ -f "$LOGFILE" ] && [ $(wc -c < "$LOGFILE") -gt $((1024*1024*5)) ]; then
        # rotate if >5MB
        mv "$LOGFILE" "$LOGFILE.$(date +%s)" || true
        # keep last 30
        ls -1t "$LOGFILE".* 2>/dev/null | tail -n +31 | xargs -r rm -f
    fi

    logger "fetch-wallpaper: started"

    # 1) Try local directory
    if img=$(choose_local); then
        echo "Using local wallpaper: $img"
        cp "$img" "$OUT_TMP"
        logger "Using local wallpaper: $img"
    else
        # remove any stale temp
        rm -f "$OUT_TMP" || true

        # 2) Prefer Unsplash (clean, high-res photos) if API key is present
        src=""
        if [ -f "$UNSPLASH_KEY_FILE" ] && command -v jq >/dev/null 2>&1; then
            KEY=$(tr -d '\n\r ' < "$UNSPLASH_KEY_FILE")
            if [ -n "$KEY" ] && download_unsplash "$KEY"; then
                src="Unsplash"
                logger "Downloaded from Unsplash"
            else
                logger "Unsplash fetch failed; trying other sources"
            fi
        fi

        # 3) Try Reddit
        if [ -z "$src" ] && command -v jq >/dev/null 2>&1 && command -v shuf >/dev/null 2>&1 && download_reddit; then
            src="Reddit"
            logger "Downloaded from Reddit"
        fi

        # 4) Try Bing
        if [ -z "$src" ] && command -v jq >/dev/null 2>&1 && download_bing; then
            src="Bing"
            logger "Downloaded from Bing"
        fi

        # 5) Fallback to picsum
        if [ -z "$src" ]; then
            logger "Falling back to Picsum"
            download_picsum && src="Picsum"
        fi

        if [ -z "$src" ]; then
            echo "All wallpaper sources failed." >&2
        else
            echo "Downloaded from $src"
        fi
    fi

    # Ensure a new file was downloaded to the temp location
    if [ ! -s "$OUT_TMP" ]; then
        echo "Download failed or file empty." >&2
        return 1
    fi

    # Archive previous wallpaper (if any) then move the new one into place
    if [ -f "$OUT_FILE" ]; then
        archive_dir="$OUT_DIR/archive"
        mkdir -p "$archive_dir"
        ts=$(date +%Y%m%d%H%M%S)
        cp -f "$OUT_FILE" "$archive_dir/daily-$ts.jpg" || true
    fi

    mv -f "$OUT_TMP" "$OUT_FILE"
    echo "Wallpaper saved to $OUT_FILE"
    logger "Wallpaper saved to $OUT_FILE"

    # Trigger theme application
    if [ -x "$HOME/.local/bin/set-wallpaper" ]; then
        "$HOME/.local/bin/set-wallpaper" "$OUT_FILE" || true
    else
        echo "set-wallpaper not found; apply-theme not invoked." >&2
    fi

    return 0
}

main "$@"
