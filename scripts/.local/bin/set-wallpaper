#!/usr/bin/env bash
set -euo pipefail

# set-wallpaper <image-path>
# Sets wallpaper using swww and applies theme via apply-theme.
# Saves state for persistence on reboot.

# Append-mode log shared with restore-wallpaper. The awk wrapper here is
# only attached when not already inside one (keeps tags readable when called
# from restore-wallpaper).
if [[ -z "${WALLPAPER_LOG_PROXY:-}" ]]; then
    LOG_FILE="$HOME/.local/share/dotfiles/wallpaper.log"
    mkdir -p "$(dirname "$LOG_FILE")"
    export WALLPAPER_LOG_PROXY=1
    exec > >(awk -v p="set-wallpaper" '{ printf "[%s %s] %s\n", strftime("%Y-%m-%d %H:%M:%S"), p, $0; fflush() }' >>"$LOG_FILE") 2>&1
fi

trap 'echo "EXIT $? at line $LINENO (cmd: ${BASH_COMMAND})"' ERR
echo "==== set-wallpaper $* ===="

STATE_FILE="$HOME/.config/current_wallpaper"

if [ "$#" -lt 1 ]; then
    echo "Usage: set-wallpaper <image-path>" >&2
    exit 2
fi

IMG="$(readlink -f "$1")"
SWWW_CMD="$(command -v swww || true)"
APPLY_THEME_CMD="$(command -v apply-theme || true)"

# 1. Save state immediately
echo "$IMG" > "$STATE_FILE"

# 2. Set Wallpaper
# Prefer swww (if available and responding). If the swww daemon isn't
# available fall back to a simpler wallpaper setter (swaybg) where possible.
fallback_set_wallpaper() {
    if command -v swaybg >/dev/null 2>&1; then
        echo "Using swaybg fallback to set wallpaper." >&2
        # Run in background so we don't block session startup
        swaybg -i "$IMG" -m fill &>/dev/null &
        disown || true
        return 0
    fi
    echo "No supported wallpaper setter found; skipping wallpaper set." >&2
    return 1
}

if [ -n "$SWWW_CMD" ]; then
    # Ensure swww daemon is ready before trying to set (up to ~5s)
    SWWW_READY=0
    for i in {1..10}; do
        if "$SWWW_CMD" query &>/dev/null; then
            SWWW_READY=1
            break
        fi
        sleep 0.5
    done

    if [ "$SWWW_READY" -eq 1 ]; then
        # Slick, fast transition: grow from center, 120fps, 0.5s
        "$SWWW_CMD" img "$IMG" \
            --transition-type grow \
            --transition-pos 0.5,0.5 \
            --transition-fps 120 \
            --transition-step 90 \
            --transition-duration 0.5 || true
    else
        echo "swww found but daemon not responding; falling back." >&2
        fallback_set_wallpaper || true
    fi
else
    fallback_set_wallpaper || true
fi

# 3. Apply Theme
if [ -n "$APPLY_THEME_CMD" ]; then
    $APPLY_THEME_CMD "$IMG" || true
else
    # try local bin path relative to this script file
    SCRIPTS_DIR=$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")
    if [ -f "$SCRIPTS_DIR/apply-theme" ]; then
        # call via bash to avoid relying on the executable bit inside the repo
        bash "$SCRIPTS_DIR/apply-theme" "$IMG" || true
    fi
fi

# 4. Tag the new wallpaper for mood classification
if command -v tag-wallpaper-moods >/dev/null 2>&1; then
    tag-wallpaper-moods --file "$IMG" --quiet &>/dev/null &
fi
