#!/usr/bin/env bash
set -euo pipefail

LOG_FILE="$HOME/.local/share/dotfiles/apply-theme.log"
mkdir -p "$(dirname "$LOG_FILE")"
>"$LOG_FILE"
exec > >(tee -a "$LOG_FILE") 2>&1

echo "--- Starting apply-theme: $(date) ---"

if [ "$#" -lt 1 ]; then
    echo "Usage: apply-theme <wallpaper-path>"
    exit 2
fi
WALLPAPER="$1"
echo "Wallpaper: $WALLPAPER"

WAL_CMD="$(command -v wal || true)"
if [ -z "$WAL_CMD" ]; then
    echo "pywal (wal) not found."
    exit 0
fi

if [ -d "$HOME/.cache/wal" ]; then
    echo "Clearing pywal cache..."
    find "$HOME/.cache/wal" -maxdepth 1 -type f -name 'colors*' -print0 | xargs -0 -r rm -f || true
    find "$HOME/.cache/wal" -maxdepth 1 -type f -name '*.json' -print0 | xargs -0 -r rm -f || true
    find "$HOME/.cache/wal/schemes" -maxdepth 1 -type f -print0 | xargs -0 -r rm -f || true
fi

echo "Generating colors with pywal..."
if ! $WAL_CMD -n -i "$WALLPAPER" -q; then
    echo "pywal failed."
    exit 1
fi
echo "pywal complete."

SEQUENCES_FILE="$HOME/.cache/wal/sequences"
if [ -f "$SEQUENCES_FILE" ]; then
    echo "Broadcasting escape sequences to open terminals..."
    for term in /dev/pts/[0-9]*; do
        if [ -w "$term" ]; then
            cat "$SEQUENCES_FILE" > "$term" 2>/dev/null || true
        fi
    done
fi


PY_COLORS="$HOME/.cache/wal/colors.json"
if [ ! -f "$PY_COLORS" ]; then
    echo "colors.json not found after pywal run. Aborting."
    exit 1
fi

echo "Updating application themes..."
BG=$(jq -r '.special.background' "$PY_COLORS")
FG=$(jq -r '.special.foreground' "$PY_COLORS")
ACCENT=$(jq -r '.colors.color2' "$PY_COLORS")

LAST_ACCENT_FILE="$HOME/.local/share/dotfiles/last_accent"
LAST_ACCENT=""
if [ -f "$LAST_ACCENT_FILE" ]; then
    LAST_ACCENT=$(cat "$LAST_ACCENT_FILE")
fi

BEST_ACCENT=$(python3 - "$PY_COLORS" "$LAST_ACCENT" <<PY
import json,sys,colorsys

def hex2rgb(h):
    h=h.lstrip('#')
    return tuple(int(h[i:i+2],16) for i in (0,2,4))

try:
    data=json.load(open(sys.argv[1]))
    colors = data.get('colors', {})

    candidates = []
    for i in range(1, 7):
        c = colors.get(f'color{i}')
        if c: candidates.append(c)

    last_accent = sys.argv[2] if len(sys.argv)>2 else ''

    best_color = None
    max_score = -1.0

    for c in candidates:
        if c == last_accent and len(candidates) > 1:
            continue

        r, g, b = hex2rgb(c)
        h, s, v = colorsys.rgb_to_hsv(r/255.0, g/255.0, b/255.0)

        score = (s * 3.0) + (v * 1.0)

        if score > max_score:
            max_score = score
            best_color = c

    if not best_color:
        best_color = colors.get('color2', '#ffffff')

    print(best_color)

except Exception as e:
    print("#ffffff")
PY
)

if [ -n "$BEST_ACCENT" ] && [ "$BEST_ACCENT" != "null" ]; then
    if [ "$BEST_ACCENT" != "$ACCENT" ]; then
        echo "Variety agent selected accent: $BEST_ACCENT (was $ACCENT)"
        ACCENT="$BEST_ACCENT"
    else
        echo "Variety agent: no better accent found; using $ACCENT"
    fi
fi

echo "$ACCENT" > "$LAST_ACCENT_FILE"

echo "Extracted Accent Color: $ACCENT"
INVERSE_ACCENT=""

if [ -x "$HOME/dotfiles/scripts/.local/bin/accent-guardian" ]; then
    "$HOME/dotfiles/scripts/.local/bin/accent-guardian" || true
fi

ALACRITTY_TEMPLATE="$HOME/dotfiles/alacritty/template.alacritty.toml"
ALACRITTY_DEST="$HOME/.config/alacritty/alacritty.toml"

if [ -f "$ALACRITTY_TEMPLATE" ]; then
    echo "Generating new Alacritty config from template..."
    TMP_COLORS=$(mktemp)

    python3 - "$PY_COLORS" <<'PY' > "$TMP_COLORS"
import json, sys
try:
    data = json.load(open(sys.argv[1]))
    s = data.get('special', {})
    c = data.get('colors', {})
    def q(val): return f'"{val}"'

    print('[colors.primary]')
    print(f'background = {q(s.get("background"))}')
    print(f'foreground = {q(s.get("foreground"))}')

    print('[colors.normal]')
    names=['black','red','green','yellow','blue','magenta','cyan','white']
    for i,n in enumerate(names): print(f'{n} = {q(c.get(f"color{i}"))}')

    print('[colors.bright]')
    for i,n in enumerate(names): print(f'{n} = {q(c.get(f"color{i+8}"))}')
except Exception as e:
    print(f"# Error generating colors: {e}")
PY

    cat "$ALACRITTY_TEMPLATE" > "$ALACRITTY_DEST.tmp"
    echo "" >> "$ALACRITTY_DEST.tmp"
    cat "$TMP_COLORS" >> "$ALACRITTY_DEST.tmp"

    mv "$ALACRITTY_DEST.tmp" "$ALACRITTY_DEST"
    rm -f "$TMP_COLORS"
    echo "Alacritty config updated."

    if ! ~/dotfiles/scripts/.local/bin/test-alacritty.sh; then
        echo "ERROR: New Alacritty config is invalid. Restoring from template."
        rm -f "$ALACRITTY_DEST"
        if [ -f "$ALACRITTY_TEMPLATE" ]; then
            cp "$ALACRITTY_TEMPLATE" "$ALACRITTY_DEST"
            echo "Restored Alacritty config from template."
        else
            echo "Restore failed: template missing at $ALACRITTY_TEMPLATE"
        fi
        exit 1
    fi
else
    echo "WARNING: Alacritty template not found at $ALACRITTY_TEMPLATE"
fi

NIRI_CONF="$HOME/.config/niri/config.kdl"
if [ -f "$NIRI_CONF" ]; then
    echo "Updating Niri focus ring to: $ACCENT"
    if grep -q "active-color" "$NIRI_CONF"; then
        sed -i -E "s/(active-color\s*\")[^\"]+(\")/\1${ACCENT}\2/" "$NIRI_CONF"
    fi
    if grep -q "inactive-color" "$NIRI_CONF"; then
         sed -i -E "s/(inactive-color\s*\")[^\"]+(\")/\1${ACCENT}\2/" "$NIRI_CONF"
    fi
fi

SWAYNC_DIR="$HOME/.config/swaync"
if [ -d "$SWAYNC_DIR" ]; then
    echo "Generating SwayNC colors..."
    cat > "$SWAYNC_DIR/colors.css" <<CSS
@define-color background ${BG}cc;
@define-color accent ${ACCENT};
@define-color text ${FG};
CSS
    if command -v swaync-client >/dev/null && pgrep -x swaync >/dev/null; then
        # reload-config first, then reload-css. -rs alone is unreliable for
        # picking up changes inside @import-ed files (colors.css).
        timeout 2 swaync-client -R  || true
        timeout 2 swaync-client -rs || true
    fi
fi

QS_DIR="$HOME/.config/quickshell"
if [ -d "$QS_DIR" ]; then
    : "Theme.qml watches ~/.cache/wal/colors.json directly via FileView; no regen needed."
fi

WOFI_DIR="$HOME/.config/wofi"
if [ -d "$WOFI_DIR" ]; then
    cat > "$WOFI_DIR/colors-wal.css" <<CSS
#input { background-color: ${BG}14; color: ${FG}; }
#entry:selected { background-color: ${ACCENT}33; color: ${FG}; }
CSS
fi

# GTK / libadwaita — write a colors-wal.css that gtk.css imports. Keeps
# Nautilus and friends in sync with the wallpaper without touching the
# tracked gtk.css overrides.
write_gtk_palette() {
    local dir=$1
    [ -d "$dir" ] || return 0
    local view_bg
    view_bg=$(python3 - "$BG" <<'PY'
import sys
h = sys.argv[1].lstrip('#')
r, g, b = int(h[0:2], 16), int(h[2:4], 16), int(h[4:6], 16)
def lighten(v): return min(255, v + 10)
print(f"#{lighten(r):02x}{lighten(g):02x}{lighten(b):02x}")
PY
)
    cat > "$dir/colors-wal.css" <<CSS
@define-color accent_color          ${ACCENT};
@define-color accent_bg_color       ${ACCENT};
@define-color accent_fg_color       ${BG};

@define-color window_bg_color       ${BG};
@define-color window_fg_color       ${FG};

@define-color view_bg_color         ${view_bg};
@define-color view_fg_color         ${FG};

@define-color headerbar_bg_color    ${BG};
@define-color headerbar_fg_color    ${FG};
@define-color headerbar_border_color ${ACCENT};

@define-color sidebar_bg_color      ${BG};
@define-color sidebar_fg_color      ${FG};
@define-color sidebar_backdrop_color ${BG};

@define-color popover_bg_color      ${view_bg};
@define-color popover_fg_color      ${FG};

@define-color card_bg_color         ${view_bg};
@define-color card_fg_color         ${FG};

@define-color borders               alpha(${FG}, 0.12);
@define-color shade_color           alpha(black, 0.36);
@define-color thumbnail_bg_color    ${view_bg};

@define-color destructive_color     #ff453a;
@define-color destructive_bg_color  #ff453a;
@define-color destructive_fg_color  ${FG};

@define-color success_color         ${ACCENT};
@define-color warning_color         #ffd60a;
@define-color error_color           #ff453a;
CSS
}

write_gtk_palette "$HOME/.config/gtk-3.0"
write_gtk_palette "$HOME/.config/gtk-4.0"
[ -f "$HOME/.config/gtk-4.0/gtk.css" ] && touch "$HOME/.config/gtk-4.0/gtk.css"

# SDDM theme — pushes colors + wallpaper to /var/lib/sddm-theme so the greeter
# (running as the sddm user, no access to ~) can read them. The directory is
# created world-readable by install.sh; if it's missing we skip silently and
# the SDDM theme falls back to its baked-in Apple defaults.
SDDM_THEME_DIR="/var/lib/sddm-theme"
if [ -d "$SDDM_THEME_DIR" ] && [ -w "$SDDM_THEME_DIR" ]; then
    sddm_view_bg=$(python3 - "$BG" <<'PY'
import sys
h = sys.argv[1].lstrip('#')
r, g, b = int(h[0:2], 16), int(h[2:4], 16), int(h[4:6], 16)
def lighten(v): return min(255, v + 10)
print(f"#{lighten(r):02x}{lighten(g):02x}{lighten(b):02x}")
PY
)
    cat > "$SDDM_THEME_DIR/theme.conf.user" <<CONF
[General]
background=${BG}
foreground=${FG}
accent=${ACCENT}
viewBg=${sddm_view_bg}
wallpaperPath=${SDDM_THEME_DIR}/wallpaper
CONF
    if [ -f "$WALLPAPER" ]; then
        cp -f -- "$WALLPAPER" "$SDDM_THEME_DIR/wallpaper.tmp"
        mv -f -- "$SDDM_THEME_DIR/wallpaper.tmp" "$SDDM_THEME_DIR/wallpaper"
    fi
    chmod 644 "$SDDM_THEME_DIR/theme.conf.user" "$SDDM_THEME_DIR/wallpaper" 2>/dev/null || true
    echo "SDDM theme refreshed at $SDDM_THEME_DIR"
fi

rm -rf "$HOME/.local/share/icons/pywal-folders" 2>/dev/null || true

echo "Reloading UI components..."

# quickshell auto-reloads palette via FileView watching ~/.cache/wal/colors.json.

if command -v niri >/dev/null; then
    echo "Signaling Niri..."
    niri msg action load-config-file || echo "Niri reload failed."
fi

echo "--- Theme application complete ---"
