#!/usr/bin/env bash
set -euo pipefail

# audio-menu ‚Äî wofi fallback for the eww audio panel. Reads audio-status,
# writes via audio-set: same data plumbing, different renderer.

WOFI="$(command -v wofi || true)"
JQ="$(command -v jq   || true)"
NOTIFY="$(command -v notify-send || true)"
PAVUCONTROL="$(command -v pavucontrol || true)"

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
AUDIO_STATUS="$SCRIPT_DIR/audio-status"
AUDIO_SET="$SCRIPT_DIR/audio-set"

require() {
    local bin=$1 name=$2
    if [ -z "$bin" ] || [ ! -x "$bin" ]; then
        echo "Error: $name not found." >&2
        [ -n "$NOTIFY" ] && "$NOTIFY" -a audio-menu "Audio menu" "$name not installed"
        exit 2
    fi
}

require "$WOFI" "wofi"
require "$JQ"   "jq"
require "$AUDIO_STATUS" "audio-status"
require "$AUDIO_SET"    "audio-set"

ICON_MUTE="Û∞ùü"
ICON_VOL_UP="Û∞ùù"
ICON_VOL_DOWN="Û∞ùû"
ICON_TOOLS="Û∞íì"
DOT_DEFAULT="‚óè"
DOT_OTHER="‚óã"

notify() {
    [ -n "$NOTIFY" ] || return 0
    "$NOTIFY" -a audio-menu "$@"
}

volume_bar() {
    local pct=$1 width=14 filled bar=""
    [ "$pct" -gt 100 ] && pct=100
    [ "$pct" -lt 0 ]   && pct=0
    filled=$(( pct * width / 100 ))
    local i
    for ((i=0; i<width; i++)); do
        if [ $i -lt $filled ]; then bar+="‚ñ∞"; else bar+="‚ñ±"; fi
    done
    printf '%s' "$bar"
}

emit_devices() {
    local state=$1 jq_key=$2 action=$3 row name label icon is_default marker
    while IFS= read -r row; do
        name=$(printf       '%s' "$row" | "$JQ" -r '.name')
        label=$(printf      '%s' "$row" | "$JQ" -r '.label')
        icon=$(printf       '%s' "$row" | "$JQ" -r '.icon')
        is_default=$(printf '%s' "$row" | "$JQ" -r '.default')
        marker=$([ "$is_default" = "true" ] && echo "$DOT_DEFAULT" || echo "$DOT_OTHER")
        printf '%s\t%s\t%s  %s  %s\n' "$action" "$name" "$icon" "$marker" "$label"
    done < <(printf '%s' "$state" | "$JQ" -c ".${jq_key}s[]")
}

# Each menu line is "<action_kind>\t<arg>\t<label>"; main() routes by kind.
build_menu() {
    local state cur_vol cur_mute cur_icon mute_label
    state=$("$AUDIO_STATUS")
    cur_vol=$(printf  '%s' "$state" | "$JQ" -r '.sink.volume   // 0')
    cur_mute=$(printf '%s' "$state" | "$JQ" -r '.sink.muted    // false')
    cur_icon=$(printf '%s' "$state" | "$JQ" -r '.sink.icon     // "Û∞ìÉ"')

    if [ "$cur_mute" = "true" ]; then
        mute_label="$ICON_MUTE  Unmute"
    else
        mute_label="$ICON_MUTE  Mute"
    fi

    printf 'noop\t-\t%s  %s  %s%%\n' "$cur_icon" "$(volume_bar "$cur_vol")" "$cur_vol"

    printf 'volume\t+5\t%s  Volume +5%%\n' "$ICON_VOL_UP"
    printf 'volume\t-5\t%s  Volume -5%%\n' "$ICON_VOL_DOWN"
    printf 'mute\tsink\t%s\n' "$mute_label"

    local p
    for p in 100 75 50 25 0; do
        printf 'volume_set\t%s\t   Set volume to %s%%\n' "$p" "$p"
    done

    printf 'sep\t-\t‚îÄ‚îÄ‚îÄ Outputs ‚îÄ‚îÄ‚îÄ\n'
    emit_devices "$state" sink   "sink"
    printf 'sep\t-\t‚îÄ‚îÄ‚îÄ Inputs ‚îÄ‚îÄ‚îÄ\n'
    emit_devices "$state" source "source"

    printf 'sep\t-\t‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ\n'
    printf 'mute\tsource\t%s  Toggle microphone mute\n' "$ICON_MUTE"
    if [ -n "$PAVUCONTROL" ]; then
        printf 'action\tpavucontrol\t%s  Open pavucontrol\n' "$ICON_TOOLS"
    fi
}

main() {
    local menu choice matched kind arg
    menu=$(build_menu)
    choice=$(printf '%s\n' "$menu" | cut -f3- \
        | "$WOFI" --dmenu \
                  --prompt "Audio" \
                  --width 460 \
                  --height 540 \
                  --cache-file /dev/null \
                  --insensitive 2>/dev/null || true)

    [ -z "$choice" ] && exit 0

    matched=$(printf '%s\n' "$menu" | awk -F'\t' -v want="$choice" '$3 == want { print $1 "\t" $2; exit }')
    [ -z "$matched" ] && exit 0
    kind=${matched%%$'\t'*}
    arg=${matched#*$'\t'}

    case "$kind" in
        sink)        "$AUDIO_SET" sink   "$arg"; notify "Output set" "$choice" ;;
        source)      "$AUDIO_SET" source "$arg"; notify "Input set"  "$choice" ;;
        volume)      "$AUDIO_SET" sink-volume "$arg" ;;
        volume_set)  "$AUDIO_SET" sink-volume "$arg" ;;
        mute)        "$AUDIO_SET" mute "$arg" ;;
        action)
            [ "$arg" = "pavucontrol" ] && [ -n "$PAVUCONTROL" ] && \
                setsid -f "$PAVUCONTROL" >/dev/null 2>&1 || true
            ;;
        sep|noop) : ;;
    esac
}

main "$@"
